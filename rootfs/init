#!/bin/sh
echo ""
echo "============================================"
echo "  Shlte OS v0.1 — BusyBox 1.36.1"
echo "============================================"
echo ""
hostname shlte-os 2>/dev/null
[ -f /etc/environment ] && . /etc/environment
echo "  $(busybox --list 2>/dev/null | wc -l) applets available"
echo ""
[ -x /etc/init.d/rcS ] && /etc/init.d/rcS
echo ""
echo "Type 'help' for commands."
echo ""
while true; do
    printf "shlte-os# "
    read -r cmd args || break
    case "$cmd" in
        help)
            echo "Commands: info, ls, cat, ps, free, uptime, sap help, reboot"
            echo "272 applets available via busybox" ;;
        info) echo "Shlte OS v0.1 — ARM64 Microkernel + BusyBox 1.36.1" ;;
        sap) /usr/bin/sap $args ;;
        reboot|exit) echo "Halting."; while true; do :; done ;;
        "") ;;
        *) /bin/busybox "$cmd" $args 2>/dev/null || echo "not found" ;;
    esac
done
